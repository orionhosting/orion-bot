{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 120,
    "arrowParens": "avoid",
    "tabWidth": 4,
    "useTabs": false,
    "sortImports": {
        "newlinesBetween": false
    },
    "ignorePatterns": ["node_modules", ".turbo", ".next", "dist", "package-lock.json", "prisma/"]
}
