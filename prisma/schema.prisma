generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// A guild settings.
model GuildSettings {
  id            String  @id
  ad_enabled    Boolean
  ad_channel_id String?
  ad_message_id String?
}

/// A guild ad state.
///
/// When a guild has the ad configured, the owner
/// receives a reward every week. This model is used
/// to keep track of the guild ad state and when the
/// rewards were given.
model GuildAdState {
  guild_id    String  @id
  /// If the ad was valid during the last check
  /// (posted, available to everyone).
  is_valid    Boolean
  /// The timestamp since when the ad is valid.
  valid_since Int?
  /// The timestamp of the last check of the guild ad state.
  updated_at  Int

  /// The timestamp of the last reward.
  /// The first reward is only given after a week (not directly after setup).
  last_reward_at Int?
}
