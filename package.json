{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "orion-bot",
    "version": "1.0.0",
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "type": "commonjs",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/the-lmc-group/orion-bot.git"
    },
    "scripts": {
        "build": "rimraf dist && swc src -d dist --copy-files --strip-leading-paths",
        "dev": "npm run build && node .",
        "start": "npm run build && npm run deploy && node .",
        "deploy": "node dist/scripts/deploy.js",
        "lint": "oxlint",
        "tslint": "tsc --noEmit",
        "format": "prettier . --write"
    },
    "dependencies": {
        "@sodiumlabs/plume-api": "^1.4.1",
        "cross-env": "^7.0.3",
        "discord.js": "^14.18.0",
        "dotenv": "^16.5.0",
        "express": "^5.1.0",
        "i18next": "^25.0.0",
        "mongoose": "^8.13.2",
        "pterodactyl.js": "^2.1.1",
        "zod": "^3.24.3",
        "@swc/cli": "^0.7.8",
        "rimraf": "^6.0.1"
    },
    "devDependencies": {
        "@swc/core": "^1.11.21",
        "@types/express": "^5.0.0",
        "oxlint": "^1.14.0",
        "prettier": "^3.5.3",
        "typescript": "^5.6.3"
    }
}
