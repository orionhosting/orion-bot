{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "orion-bot",
    "version": "1.0.0",
    "private": true,
    "license": "Apache-2.0",
    "author": "voctal",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/octarahq/orion-bot.git"
    },
    "type": "commonjs",
    "main": "dist/index.js",
    "scripts": {
        "dev": "npm run build && node .",
        "build": "rimraf dist && swc src -d dist --copy-files --strip-leading-paths",
        "start:all": "npm run deploy && node .",
        "deploy": "node dist/scripts/deploy.js",
        "lint": "tsc --noEmit && oxlint",
        "fmt": "oxfmt",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev"
    },
    "dependencies": {
        "@fastify/rate-limit": "^10.3.0",
        "@google/generative-ai": "^0.24.1",
        "@prisma/adapter-better-sqlite3": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "@sodiumlabs/cache": "^1.0.0",
        "@sodiumlabs/duration": "^1.0.2",
        "@sodiumlabs/plume-api": "^1.9.0",
        "@sodiumlabs/snowflake": "^1.0.3",
        "discord.js": "^14.25.1",
        "dotenv": "^17.3.1",
        "fastify": "^5.8.2",
        "fastify-type-provider-zod": "^6.1.0",
        "i18next": "^25.8.13",
        "luxon": "^3.7.2",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@swc/cli": "^0.8.0",
        "@types/luxon": "^3.7.1",
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0",
        "prisma": "^7.4.2",
        "rimraf": "^6.1.3",
        "typescript": "^5.9.3"
    }
}
